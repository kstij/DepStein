{
    "name": "depstein",
    "version": "0.1.1",
    "description": "Dependency health scorer for npm, PyPI, Cargo, and Go projects",
    "type": "module",
    "engines": {
        "node": ">=18.0.0"
    },
    "bin": {
        "depstein": "dist/index.js"
    },
    "files": [
        "dist/",
        "README.md"
    ],
    "scripts": {
        "build": "tsc && chmod +x dist/index.js",
        "dev": "tsx src/index.ts",
        "start": "node dist/index.js",
        "prepublishOnly": "npm run build"
    },
    "dependencies": {
        "chalk": "^5.3.0",
        "commander": "^11.1.0",
        "ink": "^4.4.1",
        "react": "^18.2.0"
    },
    "devDependencies": {
        "@types/node": "^20.10.0",
        "@types/react": "^18.2.0",
        "tsx": "^4.6.0",
        "typescript": "^5.3.0"
    },
    "keywords": [
        "dependencies",
        "audit",
        "security",
        "npm",
        "pypi",
        "cargo",
        "golang",
        "cli",
        "health"
    ],
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/kstij/DepStein.git"
    }
}
